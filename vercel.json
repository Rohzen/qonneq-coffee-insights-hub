{
    "version": 2,
    "installCommand": "npm install",
    "buildCommand": "npm run build",
    "functions": {
        "api/index.ts": {
            "maxDuration": 30
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api"
        },
        {
            "source": "/((?!assets/|favicon.ico|lovable-uploads/).*)",
            "destination": "/index.html"
        }
    ]
}
