{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "allowImportingTsExtensions": true,
        "noEmit": true,
        "strict": false,
        "noImplicitAny": false
    },
    "include": ["./**/*.ts"],
    "exclude": ["node_modules"]
}
